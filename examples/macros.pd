(defm (fun args body)
 `(def ,args ,body))

;(fun (test x y) (+ x 1))

(defm (unless cond body)
 `(if (not ,cond) ,body '()))

(def (safe-div x y)
    (unless (= y 0) (/ x y)))

(defm (when cond body)
 `(if ,cond ,body '()))

; rec macros have to be defined like this so their args get processed
(define else #t)
(defmacro (cond pairs...)
    (define (cond2 pairs)
      (when pairs
       `(if ,(car (car pairs))
            ,(cadr (car pairs))
            ,(cond2 (cdr pairs)))))
    (cond2 pairs...))

(def (even-odd xs)
     (when xs
        (cons
          (cond
            ((= 0 (car xs)) 'zero)
            ((= 0 (% (car xs) 2)) 'even)
            (else 'odd))
          (even-odd (cdr xs)))))

(defm (for pair body)
      (define bind (car pair))
      (define iter (eval (cdr pair)))
      (define (for2 xs)
        (if (not xs)
            'nil
            `((lambda (,bind)
                ,(body)
                ,(for2 (cdr xs)))
              ,(car xs))))
      (for2 iter))

(defm (for/list pair body)
      (define (for2 xs)
        (if (not xs)
            '()
            `(cons ((lambda (,bind)
                ,(body)) ,(car xs)) ,(for2 (cdr xs)))))
      (for2 iter))

(defm (for/or pair body)
      (define bind (car pair))
      (define iter (eval (cdr pair)))
      (define (for2 xs)
        (if (not xs)
            #f
            `(progn
               (define res
                 ((lambda (,bind) ,(body)) ,(car xs)))
               (if res
                 res
                 ,(for2 (cdr xs))))))
      (for2 iter))

(defm (let pairs body...)
      (define vars (map car pairs))
      (define vals (map cadr pairs))
      `((lambda ,vars @body...) @vals))

(defm (let* pairs body...)
      (define vars (map car pairs))
      (define vals (map cadr pairs))
      (define (let*2 vars vals)
        (if (|| (null? vars) (null? vals))
          `(progn @body...)
          `((lambda (,(car vars)) ,(let*2 (cdr vars) (cdr vals))) ,(car vals))))
      (let*2 vars vals))

(defm (unless cond body...)
 `(if (not ,cond) (progn @body...) '()))

(defm (when cond body...)
 `(if ,cond (progn @body...) '()))

; rec macros have to be defined like this so their args get processed
(define else #t)
(defmacro (cond pairs...)
    (define (cond2 pairs)
      (when pairs
       `(if ,(car (car pairs))
            ,(cadr (car pairs))
            ,(cond2 (cdr pairs)))))
    (cond2 pairs...))

(defm (for pair body...)
      (define bind (car pair))
      (define iter (eval (cdr pair)))
      (define (for2 xs)
        (if (not xs)
            'nil
            `((lambda (,bind)
                @body...
                ,(for2 (cdr xs)))
              ,(car xs))))
      (for2 iter))

(defm (for/list pair body...)
      (define (for2 xs)
        (if (not xs)
            '()
            `(cons ((lambda (,bind)
                @body...) ,(car xs)) ,(for2 (cdr xs)))))
      (for2 iter))

(defm (for/or pair body...)
      (define bind (car pair))
      (define iter (eval (cdr pair)))
      (define (for2 xs)
        (if (not xs)
            #f
            `(progn
               (define res
                 ((lambda (,bind) @body...) ,(car xs)))
               (if res
                 res
                 ,(for2 (cdr xs))))))
      (for2 iter))

(defm (let pairs body...)
      (define vars (map car pairs))
      (define vals (map cadr pairs))
      `((lambda ,vars @body...) @vals))

(defm (let* pairs body...)
      (define vars (map car pairs))
      (define vals (map cadr pairs))
      (define (let*2 vars vals)
        (if (|| (null? vars) (null? vals))
          `(progn @body...)
          `((lambda (,(car vars)) ,(let*2 (cdr vars) (cdr vals))) ,(car vals))))
      (let*2 vars vals))

(defm (letrec pairs body...)
      (define vars (map car pairs))
      (define vars-nil (map (lambda (v) `(,v ())) vars))
      (define set-pairs (map (lambda (p) `(set! ,(car p) ,(cadr p))) pairs))
      `(let (@vars-nil)
                @set-pairs
                @body...))

(defm (letn name pairs body...)
      (define vars (map car pairs))
      (define vals (map cadr pairs))
      `(letrec ((,name (lambda (@vars) @body...)))
         (,name @vals)))


;; Results monads
(define (ok v) (cons 'ok v))
(define (err e) (cons 'err e))

(define (res? r)
  (if (pair? r)
    (|| (= 'ok (car r))
        (= 'err (car r)))
    #f))
(define (ok? r)
  (if (pair? r) (= 'ok (car r)) #f))
(define (err? r)
  (if (pair? r) (= 'err (car r)) #f))
(define (unwrap r) (cdr r))

(define (unwrap-or-ret r)
  (if (ok? r) (unwrap r) r))

(define (map-ok f r)
  (if (ok? r)
    (ok (f (unwrap r)))
    r))

(define (and-then f r)
  (if (ok? r)
    (f (unwrap r))
    r))

(defm (let? bindings body...)
      (define (let?2 bindings)
        (if (null? bindings)
          `(progn @body...)
          (let ((var (car (car bindings)))
                (expr (cadr (car bindings))))
            `(let ((,var (unwrap-or-ret (,expr))))
               (if (err? ,var)
                 ,var
                 ,(let?2 (cdr bindings)))))))
      (let?2 bindings))

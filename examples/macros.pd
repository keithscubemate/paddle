(defm (fun args body)
 `(def ,args ,body))

;(fun (test x y) (+ x 1))

(defm (unless cond body)
 `(if (not ,cond) ,body '()))

(def (safe-div x y)
    (unless (= y 0) (/ x y)))

(defm (when cond body)
 `(if ,cond ,body '()))

; rec macros have to be defined like this so their args get processed
(defmacro (cond pairs)
    (define (cond2 pairs)
      (if (<= (len pairs) 2)
       `(if ,(car pairs) ,(cdr pairs) '())
       `(if ,(car (car pairs))
            ,(cdr (car pairs))
            ,(cond2 (cdr pairs)))))
    (cond2 pairs))

(def (count-even-odd xs)
    (if (not xs)
        0
        (+ (count-even-odd (cdr xs))
           (cond (
                ((= 0 (car xs)) 0)
                ((= 0 (% (car xs) 2)) 1)
                (#t -1))))))

(defm (for pair body)
      (define bind (car pair))
      (define iter (eval (cdr pair)))
      (define (for2 xs)
        (if (not xs)
            'nil
            `((lambda (,bind)
                ,(body)
                ,(for2 (cdr xs)))
              ,(car xs))))
      (for2 iter))

(defm (for/list pair body)
      (define bind (car pair))
      (define iter (eval (cdr pair)))
      (define (for2 xs)
        (if (not xs)
            '()
            `(cons ((lambda (,bind)
                ,(body)) ,(car xs)) ,(for2 (cdr xs)))))
      (for2 iter))

(defm (for/or pair body)
      (define bind (car pair))
      (define iter (eval (cdr pair)))
      (define (for2 xs)
        (if (not xs)
            'nil
            `(progn
               (define res
                 ((lambda (,bind) ,(body)) ,(car xs)))
               (if res
                 res
                 ,(for2 (cdr xs))))))
      (for2 iter))

(require examples/macros.pd)

(define nums '(1 3 6 4 1 2))

(define target 3)

(define (skip xs i)
  (if (<= i 0)
      xs
      (skip (cdr xs) (- i 1))))

(define (maximum-jumps nums target)
  target)

(define (mj nums t)
  (print nums)
  (if (not nums)
      1
      (progn
        (define num (car nums))
        (define nums (cdr nums))
        (define good? (lambda (nj)
                        (&& (<= (* t -1) (- nj num))
                            (>= t (- nj num)))))
        (define (try-nums ins)
          (if (not ins)
              0
              (progn
                (define in (car ins))
                (define ins (cdr ins))
                (if (good? in)
                    (+ 1 (mj ins t))
                    (try-nums ins)))))
        (try-nums nums))))

(mj nums target)
